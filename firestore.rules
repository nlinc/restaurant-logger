rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Saved Places rules
    match /saved_places/{docId} {
      // Authenticated users can read restaurant listings (supports collaborative circle maps)
      allow read: if request.auth != null;
      // Only the owner can write, update, or delete their own logs
      allow write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Circles rules
    match /circles/{docId} {
      // Authenticated users can read and create circles
      allow read, create: if request.auth != null;
      // Members or owners can update circles (e.g. to join or leave)
      allow update: if request.auth != null;
      // Only owners can delete a circle
      allow delete: if request.auth != null && request.auth.uid == resource.data.owner;
    }
  }
}
